# ---- Frontend (safe to expose; Vite requires the VITE_ prefix) ----
# Read by the browser app. The anon key is protected by row-level security.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---- Sync script only (NEVER prefixed VITE_, never in the browser) ----
# Used by sync/sync.js, run server-side / locally / on a schedule.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# worldcup26.ir — free open-source World Cup 2026 API (PRIMARY data source).
# Read endpoints need a JWT; the sync registers/logs in with these to get one.
WC_BASE=https://worldcup26.ir
WC_EMAIL=you@email.com
WC_PASS=any-password-you-choose
# Optional: paste an existing token to skip login.
# WC_TOKEN=

# openfootball fallback (public domain, schedule only) — used automatically
# if worldcup26.ir is unreachable. No account needed.
OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
